      "chart_type": "echarts",
      "insight_summary": "Edelws leads with a 40.64% average annual growth rate, followed by SUD at 34.29%. Bharti Axa and Indiafirst trail at 30.26% and 28.69%, respectively.",
      "sql_executed": "SELECT \n  life_insurer,\n  ROUND((POWER(CAST(MAX(claims_intimated_no) AS DOUBLE) / NULLIF(MIN(claims_intimated_no), 0), \n              1.0 / NULLIF(COUNT(DISTINCT year), 0)) - 1) * 100, 2) AS aagr_pct\nFROM \n  india_life_insurance_claims\nGROUP BY \n  life_insurer\nORDER BY \n  aagr_pct DESC\nLIMIT 500"
    }
